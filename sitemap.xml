/* =====================================================================
   Upcycling Patterns — Main Stylesheet
   Erasmus+ KA210-SCH Project
   ---------------------------------------------------------------------
   - Modern glass UI
   - Responsive layout
   - Admin/CMS-ready visual support
   - Accessibility improvements
   - Reduced-motion support
   - Print and high-contrast support
   ===================================================================== */

/* ============== DESIGN TOKENS ============== */
:root {
    --primary: #2f7a43;
    --primary-light: #57b26c;
    --primary-dark: #215732;
    --primary-deeper: #1a4225;

    --accent: #b8ff7a;
    --accent-soft: #e5ffd1;
    --accent-bright: #95f053;

    --text-main: #0f1b14;
    --text-soft: #5a6b60;
    --text-muted: #7a8b80;
    --text-white: #f8fff9;

    --bg-1: #f8fcf8;
    --bg-2: #eef6ef;
    --bg-3: #e7f0e8;
    --bg-dark: #0f1912;

    --glass: rgba(255, 255, 255, 0.62);
    --glass-strong: rgba(255, 255, 255, 0.78);
    --glass-border: rgba(255, 255, 255, 0.52);
    --border: rgba(16, 30, 20, 0.08);

    --danger: #b42318;
    --success: #18794e;
    --warning: #8a5a00;

    --shadow-soft: 0 16px 35px rgba(15, 27, 20, 0.08);
    --shadow-medium: 0 22px 55px rgba(15, 27, 20, 0.12);
    --shadow-strong: 0 35px 90px rgba(10, 18, 14, 0.18);
    --shadow-glow: 0 0 60px rgba(87, 178, 108, 0.25);
    --shadow-glow-strong: 0 0 80px rgba(87, 178, 108, 0.38);

    --radius-xs: 10px;
    --radius-sm: 14px;
    --radius-md: 22px;
    --radius-lg: 32px;
    --radius-xl: 42px;
    --radius-round: 999px;

    --container: 1240px;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-spring-soft: cubic-bezier(0.4, 1.4, 0.5, 1);
    --ease-smooth: cubic-bezier(0.65, 0, 0.35, 1);

    --transition: 0.45s var(--ease-out-quart);
    --transition-fast: 0.25s var(--ease-out-quart);
    --transition-slow: 0.8s var(--ease-out-expo);

    --gradient-primary: linear-gradient(135deg, var(--primary), var(--primary-light), var(--accent-bright));
    --gradient-text: linear-gradient(
            120deg,
            var(--text-main) 0%,
            var(--primary) 30%,
            var(--primary-light) 50%,
            var(--accent-bright) 70%,
            var(--primary) 100%
    );
}

/* ============== RESET ============== */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
    scroll-padding-top: 110px;
    -webkit-text-size-adjust: 100%;
    text-size-adjust: 100%;
}

html,
body {
    overflow-x: hidden;
}

body {
    min-height: 100vh;
    font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text-main);
    background:
            radial-gradient(circle at top left, rgba(87, 178, 108, 0.12), transparent 25%),
            radial-gradient(circle at top right, rgba(184, 255, 122, 0.12), transparent 22%),
            linear-gradient(180deg, var(--bg-1), var(--bg-2), var(--bg-3));
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}

a {
    color: inherit;
    text-decoration: none;
}

button,
a,
input,
textarea {
    font: inherit;
}

button {
    border: none;
    background: none;
    cursor: pointer;
}

img,
svg {
    display: block;
}

img {
    max-width: 100%;
}

ul,
ol {
    list-style: none;
}

::selection {
    background: rgba(87, 178, 108, 0.22);
    color: var(--text-main);
}

::-webkit-scrollbar {
    width: 12px;
    height: 12px;
}

::-webkit-scrollbar-track {
    background: rgba(87, 178, 108, 0.05);
}

::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--primary), var(--primary-light));
    border: 3px solid var(--bg-1);
    border-radius: var(--radius-round);
}

::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, var(--primary-dark), var(--primary));
}

/* ============== ACCESSIBILITY ============== */
.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
}

.skip-link {
    position: fixed;
    top: -100px;
    left: 20px;
    z-index: 9999;
    padding: 12px 18px;
    border-radius: var(--radius-sm);
    background: var(--primary);
    color: #fff;
    font-weight: 800;
    box-shadow: var(--shadow-medium);
    transition: top 0.35s var(--ease-spring);
}

.skip-link:focus {
    top: 18px;
}

:focus-visible {
    outline: 3px solid rgba(87, 178, 108, 0.45);
    outline-offset: 3px;
    border-radius: 6px;
}

.no-js-banner {
    padding: 12px 16px;
    background: #fff3cd;
    color: #4d3b00;
    text-align: center;
    font-weight: 800;
    border-bottom: 1px solid #e6d38a;
}

/* ============== CONTAINER ============== */
.container {
    width: min(var(--container), calc(100% - 40px));
    margin-inline: auto;
}

/* ============== LOADER ============== */
.page-loader {
    position: fixed;
    inset: 0;
    z-index: 5000;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
            radial-gradient(circle at center, rgba(184, 255, 122, 0.15), transparent 32%),
            linear-gradient(180deg, #fbfefb, #edf6ee);
    transition: opacity 0.8s var(--ease-out-expo), visibility 0.8s var(--ease-out-expo);
}

.page-loader.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loader-wrap {
    text-align: center;
    animation: loaderPulse 2s ease-in-out infinite;
}

.loader-ring {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0 auto 18px;
    border: 3px solid rgba(47, 122, 67, 0.1);
    border-top-color: var(--primary);
    border-right-color: var(--primary-light);
    border-radius: 50%;
    box-shadow: 0 0 40px rgba(87, 178, 108, 0.2);
    animation: spin 1s var(--ease-smooth) infinite;
}

.loader-ring::after {
    content: "";
    position: absolute;
    inset: -6px;
    border: 1px solid rgba(87, 178, 108, 0.15);
    border-radius: inherit;
    animation: loaderRipple 1.6s ease-out infinite;
}

.loader-wrap p {
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    animation: loaderTextShift 2s ease-in-out infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

@keyframes loaderPulse {
    0%,
    100% {
        transform: scale(1);
    }

    50% {
        transform: scale(1.03);
    }
}

@keyframes loaderRipple {
    0% {
        transform: scale(1);
        opacity: 1;
    }

    100% {
        transform: scale(1.5);
        opacity: 0;
    }
}

@keyframes loaderTextShift {
    0%,
    100% {
        letter-spacing: 0.08em;
        opacity: 0.72;
    }

    50% {
        letter-spacing: 0.16em;
        opacity: 1;
    }
}

/* ============== BACKGROUND DECORATION ============== */
.scroll-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 9000;
    background: rgba(47, 122, 67, 0.08);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: opacity 0.4s var(--ease-out-quart);
}

.scroll-progress-bar {
    display: block;
    width: 0;
    height: 100%;
    border-radius: 0 var(--radius-round) var(--radius-round) 0;
    background: linear-gradient(90deg, var(--primary), var(--primary-light), var(--accent));
    background-size: 200% 100%;
    box-shadow: 0 0 12px rgba(87, 178, 108, 0.5);
    transition: width 0.15s var(--ease-out-quart);
    animation: progressShimmer 3s linear infinite;
}

@keyframes progressShimmer {
    0% {
        background-position: 0% 50%;
    }

    100% {
        background-position: 200% 50%;
    }
}

.cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(
            circle,
            rgba(87, 178, 108, 0.22) 0%,
            rgba(184, 255, 122, 0.12) 35%,
            transparent 70%
    );
    pointer-events: none;
    z-index: 0;
    opacity: 0.32;
    mix-blend-mode: multiply;
    filter: blur(2px);
    will-change: transform;
}

.ambient {
    position: fixed;
    z-index: -5;
    border-radius: 50%;
    filter: blur(70px);
    pointer-events: none;
    animation: ambientFloat 18s ease-in-out infinite;
    will-change: transform;
}

.ambient-1 {
    width: 320px;
    height: 320px;
    top: 80px;
    left: -80px;
    background: rgba(87, 178, 108, 0.2);
}

.ambient-2 {
    width: 340px;
    height: 340px;
    top: 22%;
    right: -70px;
    background: rgba(184, 255, 122, 0.16);
    animation-delay: -3s;
    animation-duration: 22s;
}

.ambient-3 {
    width: 300px;
    height: 300px;
    bottom: 80px;
    left: 45%;
    background: rgba(123, 219, 190, 0.16);
    animation-delay: -6s;
    animation-duration: 26s;
}

.noise-layer {
    position: fixed;
    inset: 0;
    z-index: -6;
    opacity: 0.04;
    pointer-events: none;
    background-image:
            radial-gradient(circle at 20% 20%, #000 0.7px, transparent 0.9px),
            radial-gradient(circle at 70% 60%, #000 0.6px, transparent 0.9px),
            radial-gradient(circle at 50% 85%, #000 0.8px, transparent 1px);
    background-size: 120px 120px, 150px 150px, 180px 180px;
}

.grid-layer {
    position: fixed;
    inset: 0;
    z-index: -7;
    pointer-events: none;
    background-image:
            linear-gradient(rgba(15, 27, 20, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(15, 27, 20, 0.03) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: radial-gradient(circle at center, black 42%, transparent 88%);
    -webkit-mask-image: radial-gradient(circle at center, black 42%, transparent 88%);
    animation: gridDrift 60s linear infinite;
}

@keyframes ambientFloat {
    0%,
    100% {
        transform: translate3d(0, 0, 0) scale(1);
    }

    25% {
        transform: translate3d(30px, -20px, 0) scale(1.05);
    }

    50% {
        transform: translate3d(16px, -30px, 0) scale(1.08);
    }

    75% {
        transform: translate3d(-20px, -10px, 0) scale(1.03);
    }
}

@keyframes gridDrift {
    0% {
        background-position: 0 0;
    }

    100% {
        background-position: 34px 34px;
    }
}

/* ============== HEADER ============== */
.site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 3000;
    padding: 18px 0;
    transition: padding 0.5s var(--ease-out-expo);
}

.site-header.scrolled {
    padding: 12px 0;
}

.navbar {
    position: relative;
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 0 18px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: var(--radius-round);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: var(--shadow-soft);
    transition: background 0.5s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
}

.site-header.scrolled .navbar {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow-medium), 0 0 40px rgba(87, 178, 108, 0.08);
}

.logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    transition: transform 0.4s var(--ease-spring);
}

.logo:hover {
    transform: scale(1.03);
}

.logo-mark {
    width: 50px;
    height: 50px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 14px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(47, 122, 67, 0.14);
    transition: box-shadow 0.4s var(--ease-out-quart), transform 0.5s var(--ease-spring);
}

.logo:hover .logo-mark {
    transform: rotate(-3deg);
    box-shadow: 0 16px 38px rgba(47, 122, 67, 0.28), var(--shadow-glow);
}

.site-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
}

.logo:hover .site-logo {
    transform: scale(1.1);
}

.logo-text {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-main);
    white-space: nowrap;
    transition: color 0.3s var(--ease-out-quart);
}

.logo:hover .logo-text {
    color: var(--primary);
}

.nav-menu-desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
}

.nav-menu-desktop .nav-link {
    padding: 11px 15px;
    font-size: 0.94rem;
}

.nav-link {
    position: relative;
    border-radius: var(--radius-round);
    color: var(--text-soft);
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    transition:
            color 0.35s var(--ease-out-quart),
            background 0.35s var(--ease-out-quart),
            transform 0.3s var(--ease-spring);
}

.nav-link::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(87, 178, 108, 0.14), rgba(184, 255, 122, 0.1));
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.35s var(--ease-out-quart), transform 0.4s var(--ease-spring);
}

.nav-link::after {
    content: "";
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 7px;
    height: 2px;
    border-radius: var(--radius-round);
    background: linear-gradient(90deg, var(--primary), var(--accent));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.45s var(--ease-out-expo);
    box-shadow: 0 2px 8px rgba(87, 178, 108, 0.4);
}

.nav-link:hover,
.nav-link.active,
.nav-link[aria-current="page"] {
    color: var(--primary);
    background: rgba(87, 178, 108, 0.08);
    transform: translateY(-1px);
}

.nav-link:hover::before,
.nav-link.active::before,
.nav-link[aria-current="page"]::before {
    opacity: 1;
    transform: scale(1);
}

.nav-link:hover::after,
.nav-link.active::after,
.nav-link[aria-current="page"]::after {
    transform: scaleX(1);
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
}

.language-switcher {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    padding: 4px;
    border: 1px solid rgba(47, 122, 67, 0.08);
    border-radius: var(--radius-round);
    background: rgba(87, 178, 108, 0.08);
    transition: box-shadow 0.4s var(--ease-out-quart);
}

.language-switcher:hover {
    box-shadow: 0 4px 16px rgba(87, 178, 108, 0.12);
}

.lang-btn {
    min-width: 42px;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--radius-round);
    color: var(--text-soft);
    font-size: 0.85rem;
    font-weight: 900;
    transition:
            color 0.35s var(--ease-out-quart),
            background 0.35s var(--ease-out-quart),
            transform 0.3s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart);
}

.lang-btn:hover {
    color: var(--primary);
    background: rgba(255, 255, 255, 0.8);
    transform: translateY(-1px);
}

.lang-btn.active,
.lang-btn[aria-pressed="true"] {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: #fff;
    box-shadow:
            0 10px 22px rgba(47, 122, 67, 0.28),
            inset 0 1px 0 rgba(255, 255, 255, 0.25);
}

.desktop-toggle {
    display: inline-flex;
    width: 46px;
    height: 46px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
    border-radius: 14px;
    background: rgba(87, 178, 108, 0.08);
    transition:
            background 0.4s var(--ease-out-quart),
            transform 0.4s var(--ease-spring);
}

.desktop-toggle:hover {
    background: rgba(87, 178, 108, 0.18);
    transform: scale(1.05);
}

.desktop-toggle.active {
    background: rgba(87, 178, 108, 0.2);
    transform: rotate(90deg);
}

.desktop-toggle span {
    width: 20px;
    height: 2px;
    border-radius: var(--radius-round);
    background: var(--text-main);
    transition:
            transform 0.5s var(--ease-out-expo),
            opacity 0.35s var(--ease-out-quart);
}

.desktop-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}

.desktop-toggle.active span:nth-child(2) {
    opacity: 0;
    transform: translateX(-10px);
}

.desktop-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}

.nav-menu-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: min(340px, calc(100vw - 24px));
    max-height: calc(100vh - 120px);
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px;
    overflow-y: auto;
    z-index: 4000;
    border: 1px solid rgba(16, 30, 20, 0.06);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow:
            0 24px 58px rgba(15, 35, 20, 0.16),
            inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-16px) scale(0.96);
    transform-origin: top right;
    transition:
            opacity 0.4s var(--ease-out-expo),
            transform 0.5s var(--ease-spring);
}

.nav-menu-dropdown.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
}

.nav-menu-dropdown .nav-link {
    padding: 13px 16px;
    border-radius: 16px;
    opacity: 0;
    transform: translateX(20px);
    transition:
            opacity 0.4s var(--ease-out-quart),
            transform 0.5s var(--ease-spring),
            color 0.3s var(--ease-out-quart),
            background 0.3s var(--ease-out-quart);
}

.nav-menu-dropdown.open .nav-link {
    opacity: 1;
    transform: translateX(0);
}

.nav-menu-dropdown.open .nav-link:nth-child(1) { transition-delay: 0.05s; }
.nav-menu-dropdown.open .nav-link:nth-child(2) { transition-delay: 0.08s; }
.nav-menu-dropdown.open .nav-link:nth-child(3) { transition-delay: 0.11s; }
.nav-menu-dropdown.open .nav-link:nth-child(4) { transition-delay: 0.14s; }
.nav-menu-dropdown.open .nav-link:nth-child(5) { transition-delay: 0.17s; }
.nav-menu-dropdown.open .nav-link:nth-child(6) { transition-delay: 0.2s; }
.nav-menu-dropdown.open .nav-link:nth-child(7) { transition-delay: 0.23s; }
.nav-menu-dropdown.open .nav-link:nth-child(8) { transition-delay: 0.26s; }

.admin-nav-link {
    margin-top: 6px;
    color: var(--primary);
    background: rgba(87, 178, 108, 0.1);
    border: 1px dashed rgba(47, 122, 67, 0.24);
}

.admin-nav-link::after {
    display: none;
}

/* ============== HERO ============== */
.hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 155px 0 90px;
    overflow: hidden;
}

.hero-container {
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: 54px;
    align-items: center;
}

.hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(28px);
    pointer-events: none;
    animation: orbDrift 16s ease-in-out infinite;
    will-change: transform;
}

.hero-orb-1 {
    width: 200px;
    height: 200px;
    left: 7%;
    top: 18%;
    background: rgba(87, 178, 108, 0.2);
}

.hero-orb-2 {
    width: 260px;
    height: 260px;
    right: 10%;
    top: 10%;
    background: rgba(184, 255, 122, 0.18);
    animation-delay: -3s;
    animation-duration: 20s;
}

.hero-orb-3 {
    width: 220px;
    height: 220px;
    right: 14%;
    bottom: 12%;
    background: rgba(120, 205, 170, 0.16);
    animation-delay: -6s;
    animation-duration: 24s;
}

@keyframes orbDrift {
    0%,
    100% {
        transform: translate3d(0, 0, 0) scale(1);
    }

    25% {
        transform: translate3d(18px, -24px, 0) scale(1.06);
    }

    50% {
        transform: translate3d(12px, -16px, 0) scale(1.1);
    }

    75% {
        transform: translate3d(-14px, -20px, 0) scale(1.04);
    }
}

.hero-content {
    position: relative;
    z-index: 1;
    max-width: 710px;
}

.hero-content > * {
    opacity: 0;
    transform: translateY(28px);
    animation: heroEnter 1s var(--ease-out-expo) forwards;
}

.hero-content .eyebrow { animation-delay: 0.2s; }
.hero-content .hero-title { animation-delay: 0.35s; }
.hero-content .hero-description { animation-delay: 0.55s; }
.hero-content .hero-buttons { animation-delay: 0.7s; }
.hero-content .hero-stats { animation-delay: 0.85s; }

@keyframes heroEnter {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.eyebrow,
.section-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
}

.eyebrow::before,
.section-tag::before {
    content: "";
    width: 38px;
    height: 2px;
    flex-shrink: 0;
    border-radius: var(--radius-round);
    background: linear-gradient(90deg, var(--primary), var(--accent));
    transform-origin: left;
    animation: eyebrowLine 2.5s ease-in-out infinite;
}

@keyframes eyebrowLine {
    0%,
    100% {
        transform: scaleX(1);
        opacity: 1;
    }

    50% {
        transform: scaleX(1.4);
        opacity: 0.7;
    }
}

.hero-title {
    margin-bottom: 22px;
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: clamp(3.1rem, 8vw, 6.4rem);
    line-height: 0.93;
    font-weight: 700;
    letter-spacing: -0.05em;
}

.hero-title-line {
    display: block;
}

.title-shift {
    background: var(--gradient-text);
    background-size: 300% 300%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    animation: shimmerText 8s ease-in-out infinite;
}

@keyframes shimmerText {
    0%,
    100% {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }
}

.hero-description {
    max-width: 620px;
    margin-bottom: 30px;
    color: var(--text-soft);
    font-size: 1.08rem;
}

.hero-buttons {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 36px;
}

.hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
}

.stat-card {
    min-width: 150px;
    padding: 18px 20px;
    border-radius: 24px;
    transition: transform 0.45s var(--ease-spring), box-shadow 0.45s var(--ease-out-quart);
}

.stat-card:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow: var(--shadow-medium), 0 0 30px rgba(87, 178, 108, 0.15);
}

.stat-number {
    display: block;
    margin-bottom: 4px;
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
}

.stat-card p {
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 800;
}

/* ============== BUTTONS ============== */
.btn {
    position: relative;
    min-height: 58px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0 26px;
    isolation: isolate;
    overflow: hidden;
    border-radius: var(--radius-round);
    font-size: 0.97rem;
    font-weight: 900;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition:
            transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart),
            background 0.3s var(--ease-out-quart);
}

.btn::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 20%, rgba(255, 255, 255, 0.3) 50%, transparent 80%);
    transform: translateX(-120%);
    transition: transform 0.9s var(--ease-out-expo);
}

.btn::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.25);
}

.btn:hover::before {
    transform: translateX(120%);
}

.btn:hover {
    transform: translateY(-3px) scale(1.02);
}

.btn:active {
    transform: translateY(-1px) scale(0.98);
    transition-duration: 0.1s;
}

.btn-arrow {
    display: inline-flex;
    font-size: 1.1em;
    transition: transform 0.4s var(--ease-spring);
}

.btn:hover .btn-arrow {
    transform: translateX(5px);
}

.btn-primary {
    color: #fff;
    background: linear-gradient(135deg, var(--primary), var(--primary-light), #86d85d);
    background-size: 200% 200%;
    background-position: 0% 50%;
    box-shadow:
            0 18px 42px rgba(47, 122, 67, 0.28),
            inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition:
            transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart),
            background-position 0.6s var(--ease-out-quart);
}

.btn-primary:hover {
    background-position: 100% 50%;
    box-shadow:
            0 26px 56px rgba(47, 122, 67, 0.38),
            0 0 40px rgba(87, 178, 108, 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.btn-secondary {
    color: var(--primary);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(47, 122, 67, 0.12);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(47, 122, 67, 0.25);
    box-shadow: var(--shadow-medium), 0 0 30px rgba(87, 178, 108, 0.15);
}

.btn[aria-disabled="true"],
.btn:disabled,
button[aria-disabled="true"] {
    opacity: 0.55;
    cursor: not-allowed;
    pointer-events: none;
}

/* ============== GLASS UI ============== */
.glass-card,
.glass-panel,
.glass-chip {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.56));
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: var(--shadow-soft);
    transition:
            transform 0.5s var(--ease-out-expo),
            box-shadow 0.5s var(--ease-out-expo),
            border-color 0.4s var(--ease-out-quart);
}

.glass-card::before,
.glass-panel::before,
.glass-chip::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
            130deg,
            rgba(255, 255, 255, 0.32) 0%,
            transparent 38%,
            transparent 62%,
            rgba(255, 255, 255, 0.2) 100%
    );
}

/* ============== HERO VISUAL ============== */
.hero-visual {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(30px) scale(0.96);
    animation: heroVisualEnter 1.2s var(--ease-out-expo) 0.5s forwards;
}

@keyframes heroVisualEnter {
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.hero-image-card {
    position: relative;
    width: min(100%, 580px);
    margin-left: 30px;
    padding: 14px;
    border-radius: 32px;
    box-shadow: var(--shadow-strong);
    will-change: transform;
    animation: heroImageFloat 8s ease-in-out infinite;
    transition:
            box-shadow 0.6s var(--ease-out-expo),
            transform 0.6s var(--ease-out-expo);
}

.hero-image-card:hover {
    box-shadow: var(--shadow-strong), 0 0 80px rgba(87, 178, 108, 0.25);
}

.hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 24px;
    transition: transform 0.8s var(--ease-out-expo);
}

.hero-image-card:hover .hero-image {
    transform: scale(1.04);
}

.hero-image-overlay {
    position: absolute;
    inset: 14px;
    z-index: 1;
    border-radius: 24px;
    background: linear-gradient(180deg, transparent 60%, rgba(15, 27, 20, 0.1) 100%);
    pointer-events: none;
}

.hero-image-glow {
    position: absolute;
    inset: -20px;
    z-index: -1;
    border-radius: 40px;
    background: radial-gradient(circle at center, rgba(87, 178, 108, 0.2), transparent 70%);
    opacity: 0;
    filter: blur(20px);
    transition: opacity 0.6s var(--ease-out-quart);
}

.hero-image-card:hover .hero-image-glow {
    opacity: 1;
}

@keyframes heroImageFloat {
    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-10px);
    }
}

.floating-chip {
    position: absolute;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.95);
    color: var(--text-main);
    font-size: 0.92rem;
    font-weight: 900;
    white-space: nowrap;
    box-shadow: 0 14px 32px rgba(15, 27, 20, 0.12);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    will-change: transform;
    transition:
            transform 0.4s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart);
}

.floating-chip:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 20px 44px rgba(15, 27, 20, 0.15), var(--shadow-glow);
}

.chip-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 12px var(--primary);
    animation: chipPulse 2s ease-in-out infinite;
}

.chip-dot-accent {
    background: var(--accent-bright);
    box-shadow: 0 0 12px var(--accent-bright);
}

.chip-1 {
    top: 18px;
    left: 50px;
    animation: floatY 6s ease-in-out infinite;
}

.chip-3 {
    bottom: 10px;
    left: 75px;
    animation: floatY 6.5s ease-in-out infinite 1.5s;
}

@keyframes chipPulse {
    0%,
    100% {
        opacity: 1;
        transform: scale(1);
    }

    50% {
        opacity: 0.6;
        transform: scale(1.3);
    }
}

@keyframes floatY {
    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-14px);
    }
}

.scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 26px;
    width: 32px;
    height: 54px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    border: 2px solid rgba(47, 122, 67, 0.25);
    border-radius: var(--radius-round);
    transform: translateX(-50%);
    animation: scrollIndicatorPulse 2.5s ease-in-out infinite;
}

.scroll-indicator span {
    width: 6px;
    height: 10px;
    border-radius: var(--radius-round);
    background: linear-gradient(180deg, var(--primary), var(--accent));
    animation: scrollDot 1.8s infinite var(--ease-out-expo);
}

@keyframes scrollIndicatorPulse {
    0%,
    100% {
        border-color: rgba(47, 122, 67, 0.25);
        box-shadow: none;
    }

    50% {
        border-color: rgba(47, 122, 67, 0.5);
        box-shadow: 0 0 20px rgba(87, 178, 108, 0.2);
    }
}

@keyframes scrollDot {
    0% {
        opacity: 0;
        transform: translateY(0);
    }

    30% {
        opacity: 1;
    }

    100% {
        opacity: 0;
        transform: translateY(20px);
    }
}

/* ============== SECTIONS ============== */
.section {
    position: relative;
    padding: 110px 0;
}

.section-heading {
    max-width: 860px;
    margin: 0 auto 58px;
    text-align: center;
}

.section-heading h2 {
    margin-bottom: 16px;
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    line-height: 1.07;
    font-weight: 700;
    letter-spacing: -0.035em;
}

.section-text {
    max-width: 760px;
    margin: 0 auto;
    color: var(--text-soft);
    font-size: 1.03rem;
}

.section-glow {
    background: radial-gradient(ellipse at 50% 0%, rgba(87, 178, 108, 0.08), transparent 60%);
}

.project-section {
    background: linear-gradient(180deg, rgba(236, 244, 238, 0.5), rgba(248, 252, 248, 0.85));
}

/* ============== GRIDS ============== */
.about-grid,
.highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.project-layout {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}

.timeline-grid,
.gallery-grid,
.news-grid,
.outputs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.partners-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}

/* ============== CARDS ============== */
.info-card,
.project-card,
.highlight-item,
.timeline-card,
.news-card,
.output-card,
.partner-card {
    border-radius: 30px;
    transition:
            transform 0.5s var(--ease-out-expo),
            box-shadow 0.5s var(--ease-out-expo),
            border-color 0.4s var(--ease-out-quart);
}

.info-card,
.project-card,
.highlight-item {
    padding: 32px 28px;
    will-change: transform;
}

.timeline-card,
.news-card,
.output-card,
.partner-card {
    padding: 30px 26px;
}

.info-card:hover,
.project-card:hover,
.highlight-item:hover,
.timeline-card:hover,
.news-card:hover,
.output-card:hover,
.partner-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-medium), 0 0 40px rgba(87, 178, 108, 0.12);
    border-color: rgba(87, 178, 108, 0.25);
}

.info-card h3,
.project-card h3,
.highlight-item h3,
.timeline-card h3,
.news-card h3,
.output-card h3,
.partner-card h3,
.mission-item h3,
.contact-info-card h3,
.contact-form h3 {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
}

.info-card h3,
.project-card h3,
.highlight-item h3,
.timeline-card h3,
.news-card h3,
.output-card h3,
.partner-card h3 {
    margin-bottom: 12px;
    font-size: 1.24rem;
    line-height: 1.18;
    transition: color 0.3s var(--ease-out-quart);
}

.info-card:hover h3,
.project-card:hover h3,
.highlight-item:hover h3,
.timeline-card:hover h3,
.news-card:hover h3,
.output-card:hover h3,
.partner-card:hover h3 {
    color: var(--primary);
}

.info-card p,
.project-card p,
.highlight-item p,
.timeline-card p,
.news-card p,
.output-card p,
.mission-item p,
.partner-card p,
.faq-item p {
    color: var(--text-soft);
    font-size: 0.97rem;
}

.info-icon,
.contact-icon {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(87, 178, 108, 0.16), rgba(184, 255, 122, 0.22));
    color: var(--primary);
    overflow: hidden;
    transition: transform 0.5s var(--ease-spring), box-shadow 0.4s var(--ease-out-quart);
}

.info-icon {
    width: 60px;
    height: 60px;
    margin-bottom: 20px;
    border-radius: 18px;
}

.info-icon svg {
    width: 28px;
    height: 28px;
    position: relative;
    z-index: 1;
    transition: transform 0.5s var(--ease-spring);
}

.info-card:hover .info-icon {
    transform: scale(1.1) rotate(-5deg);
    box-shadow: 0 8px 24px rgba(87, 178, 108, 0.25);
}

.info-card:hover .info-icon svg {
    transform: scale(1.1);
}

.card-num,
.timeline-step,
.mission-num,
.news-date {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Space Grotesk", monospace;
    font-weight: 700;
}

.card-num {
    width: 42px;
    height: 42px;
    margin-bottom: 16px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(87, 178, 108, 0.12), rgba(184, 255, 122, 0.18));
    color: var(--primary);
    font-size: 0.9rem;
    letter-spacing: -0.02em;
    transition: transform 0.5s var(--ease-spring), box-shadow 0.4s var(--ease-out-quart);
}

.highlight-item:hover .card-num {
    transform: scale(1.08) rotate(-4deg);
    box-shadow: 0 8px 20px rgba(87, 178, 108, 0.25);
}

.activity-icon,
.detail-icon,
.output-icon,
.tab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.activity-icon,
.detail-icon,
.output-icon {
    margin-bottom: 16px;
    font-size: 2rem;
    line-height: 1;
    transition: transform 0.5s var(--ease-spring);
}

.project-card:hover .activity-icon,
.project-card:hover .detail-icon,
.output-card:hover .output-icon {
    transform: scale(1.15) rotate(-8deg);
}

/* ============== MISSION STRIP ============== */
.mission-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 32px;
    padding: 22px;
    border-radius: 30px;
}

.mission-item {
    position: relative;
    padding: 24px 22px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.5);
    transition:
            transform 0.45s var(--ease-spring),
            background 0.4s var(--ease-out-quart);
}

.mission-item:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.8);
}

.mission-num {
    margin-bottom: 10px;
    padding: 4px 10px;
    border-radius: var(--radius-round);
    background: rgba(87, 178, 108, 0.12);
    color: var(--primary);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
}

.mission-item h3 {
    margin-bottom: 8px;
    font-size: 1.15rem;
}

/* ============== TABS ============== */
.tabs-wrapper {
    max-width: 1100px;
    margin: 0 auto;
}

.tabs-nav {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 40px;
    padding: 8px;
    border-radius: var(--radius-round);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
}

.tabs-nav::-webkit-scrollbar {
    display: none;
}

.tab-btn {
    position: relative;
    z-index: 2;
    flex: 1;
    min-width: max-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 20px;
    border-radius: var(--radius-round);
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 800;
    white-space: nowrap;
    transition:
            color 0.4s var(--ease-out-quart),
            transform 0.3s var(--ease-spring);
}

.tab-icon {
    width: 24px;
    height: 24px;
    font-size: 1.12rem;
    line-height: 1;
    transition: transform 0.4s var(--ease-spring);
}

.tab-icon svg {
    width: 100%;
    height: 100%;
}

.tab-btn:hover {
    color: var(--primary);
}

.tab-btn:hover .tab-icon {
    transform: scale(1.15) rotate(-5deg);
}

.tab-btn.active {
    color: #fff;
}

.tab-btn.active .tab-icon {
    transform: scale(1.05);
}

.tab-indicator {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 1;
    height: calc(100% - 16px);
    border-radius: var(--radius-round);
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    box-shadow:
            0 10px 24px rgba(47, 122, 67, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition:
            transform 0.55s var(--ease-spring-soft),
            width 0.55s var(--ease-spring-soft);
    will-change: transform, width;
}

.tabs-content {
    position: relative;
}

.tab-panel {
    animation: tabPanelEnter 0.6s var(--ease-out-expo);
}

.tab-panel[hidden] {
    display: none;
}

@keyframes tabPanelEnter {
    from {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.tab-panel.active .highlight-item,
.tab-panel.active .timeline-card,
.tab-panel.active .project-card,
.tab-panel.active .gallery-card,
.tab-panel.active .news-card,
.tab-panel.active .output-card {
    opacity: 0;
    transform: translateY(20px);
    animation: cardCascade 0.7s var(--ease-out-expo) forwards;
}

.tab-panel.active .highlight-item:nth-child(1),
.tab-panel.active .timeline-card:nth-child(1),
.tab-panel.active .project-card:nth-child(1),
.tab-panel.active .gallery-card:nth-child(1),
.tab-panel.active .news-card:nth-child(1),
.tab-panel.active .output-card:nth-child(1) { animation-delay: 0.05s; }

.tab-panel.active .highlight-item:nth-child(2),
.tab-panel.active .timeline-card:nth-child(2),
.tab-panel.active .project-card:nth-child(2),
.tab-panel.active .gallery-card:nth-child(2),
.tab-panel.active .news-card:nth-child(2),
.tab-panel.active .output-card:nth-child(2) { animation-delay: 0.12s; }

.tab-panel.active .highlight-item:nth-child(3),
.tab-panel.active .timeline-card:nth-child(3),
.tab-panel.active .project-card:nth-child(3),
.tab-panel.active .gallery-card:nth-child(3),
.tab-panel.active .news-card:nth-child(3),
.tab-panel.active .output-card:nth-child(3) { animation-delay: 0.19s; }

.tab-panel.active .highlight-item:nth-child(4),
.tab-panel.active .timeline-card:nth-child(4),
.tab-panel.active .project-card:nth-child(4),
.tab-panel.active .gallery-card:nth-child(4) { animation-delay: 0.26s; }

.tab-panel.active .highlight-item:nth-child(5),
.tab-panel.active .timeline-card:nth-child(5),
.tab-panel.active .gallery-card:nth-child(5) { animation-delay: 0.33s; }

.tab-panel.active .highlight-item:nth-child(6),
.tab-panel.active .timeline-card:nth-child(6),
.tab-panel.active .gallery-card:nth-child(6) { animation-delay: 0.4s; }

@keyframes cardCascade {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ============== TIMELINE ============== */
.timeline-step {
    position: relative;
    width: 56px;
    height: 56px;
    margin-bottom: 20px;
    overflow: hidden;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: #fff;
    font-size: 1rem;
    box-shadow:
            0 16px 30px rgba(47, 122, 67, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition: transform 0.5s var(--ease-spring), box-shadow 0.4s var(--ease-out-quart);
}

.timeline-step::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transform: translateX(-100%);
    transition: transform 0.7s var(--ease-out-expo);
}

.timeline-card:hover .timeline-step {
    transform: scale(1.1) rotate(-5deg);
    box-shadow:
            0 22px 40px rgba(47, 122, 67, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.timeline-card:hover .timeline-step::before {
    transform: translateX(100%);
}

/* ============== GALLERY ============== */
.gallery-card {
    padding: 14px;
    border-radius: 30px;
    cursor: pointer;
    transition:
            transform 0.5s var(--ease-out-expo),
            box-shadow 0.5s var(--ease-out-expo);
}

.gallery-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-medium), 0 0 40px rgba(87, 178, 108, 0.15);
}

.gallery-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    margin-bottom: 14px;
    overflow: hidden;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(87, 178, 108, 0.06), rgba(184, 255, 122, 0.04));
}

.gallery-img-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 60%, rgba(15, 27, 20, 0.25));
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quart);
}

.gallery-card:hover .gallery-img-wrap::after {
    opacity: 1;
}

.gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.95);
    transition:
            transform 0.7s var(--ease-out-expo),
            filter 0.5s var(--ease-out-quart);
}

.gallery-card:hover img {
    transform: scale(1.06);
    filter: saturate(1.1);
}

.gallery-card figcaption {
    padding: 0 6px 6px;
    color: var(--text-soft);
    font-size: 0.95rem;
    font-weight: 800;
    transition: color 0.3s var(--ease-out-quart);
}

.gallery-card:hover figcaption {
    color: var(--primary);
}

/* ============== NEWS / OUTPUTS ============== */
.news-date {
    margin-bottom: 16px;
    padding: 8px 14px;
    border-radius: var(--radius-round);
    background: rgba(87, 178, 108, 0.14);
    color: var(--primary);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    transition: background 0.4s var(--ease-out-quart), transform 0.4s var(--ease-spring);
}

.news-card:hover .news-date {
    background: rgba(87, 178, 108, 0.22);
    transform: scale(1.05);
}

.news-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    color: var(--primary);
    font-weight: 900;
    cursor: pointer;
    transition:
            gap 0.3s var(--ease-out-quart),
            opacity 0.3s var(--ease-out-quart);
}

.news-link::after {
    content: "→";
    transition: transform 0.4s var(--ease-spring);
}

.news-link:hover {
    gap: 10px;
}

.news-link:hover::after {
    transform: translateX(4px);
}

.news-link[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
}

.output-card .btn {
    margin-top: 18px;
}

/* ============== PARTNERS ============== */
.partner-card {
    position: relative;
    overflow: hidden;
    padding: 32px 28px;
}

.partner-flag {
    position: relative;
    width: 56px;
    height: 56px;
    margin-bottom: 18px;
    overflow: hidden;
    border-radius: 16px;
    box-shadow: 0 8px 18px rgba(15, 27, 20, 0.12);
    transition: transform 0.5s var(--ease-spring), box-shadow 0.4s var(--ease-out-quart);
}

.partner-card:hover .partner-flag {
    transform: scale(1.08) rotate(-4deg);
    box-shadow: 0 12px 28px rgba(15, 27, 20, 0.18);
}

.partner-flag::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent 50%);
    pointer-events: none;
}

.flag-tr,
.flag-mk,
.flag-lt,
.flag-pl {
    display: block;
    width: 100%;
    height: 100%;
}

.flag-tr {
    position: relative;
    background: #e30a17;
}

.flag-tr::before {
    content: "★";
    position: absolute;
    top: 50%;
    left: 65%;
    color: #fff;
    font-size: 1.4rem;
    transform: translate(-50%, -50%);
}

.flag-tr::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 32%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #e30a17;
    box-shadow: -6px 0 0 0 #fff;
    transform: translate(-50%, -50%);
}

.flag-mk {
    position: relative;
    overflow: hidden;
    background: #d20000;
}

.flag-mk::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
            conic-gradient(
                    from 0deg at 50% 50%,
                    transparent 0deg,
                    transparent 38deg,
                    #ffe600 38deg,
                    #ffe600 52deg,
                    transparent 52deg,
                    transparent 128deg,
                    #ffe600 128deg,
                    #ffe600 142deg,
                    transparent 142deg
            );
    opacity: 0.85;
}

.flag-mk::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #ffe600;
    box-shadow: 0 0 0 3px #d20000;
    transform: translate(-50%, -50%);
}

.flag-lt {
    background:
            linear-gradient(
                    180deg,
                    #fdb913 0%,
                    #fdb913 33.33%,
                    #006a44 33.33%,
                    #006a44 66.66%,
                    #c1272d 66.66%,
                    #c1272d 100%
            );
}

.flag-pl {
    background:
            linear-gradient(
                    180deg,
                    #fff 0%,
                    #fff 50%,
                    #dc143c 50%,
                    #dc143c 100%
            );
}

.partner-info p {
    margin-bottom: 6px;
    line-height: 1.55;
}

.partner-info p:last-child {
    margin-bottom: 0;
}

.partner-info strong {
    color: var(--text-main);
    font-weight: 800;
}

.partner-badge {
    position: absolute;
    top: 24px;
    right: 24px;
    padding: 6px 12px;
    border-radius: var(--radius-round);
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 6px 14px rgba(47, 122, 67, 0.25);
}

.partner-badge-alt {
    background: rgba(87, 178, 108, 0.12);
    color: var(--primary);
    border: 1px solid rgba(47, 122, 67, 0.15);
    box-shadow: none;
}

/* ============== FAQ ============== */
.faq-list {
    max-width: 900px;
    display: grid;
    gap: 18px;
    margin: 0 auto;
}

.faq-item {
    overflow: hidden;
    border-radius: 26px;
    transition:
            transform 0.4s var(--ease-out-expo),
            box-shadow 0.4s var(--ease-out-expo);
}

.faq-item:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-medium);
}

.faq-item[open] {
    box-shadow: var(--shadow-medium), 0 0 40px rgba(87, 178, 108, 0.1);
}

.faq-item summary {
    position: relative;
    padding: 24px 60px 24px 26px;
    border-radius: 26px;
    color: var(--text-main);
    cursor: pointer;
    font-size: 1.02rem;
    font-weight: 800;
    list-style: none;
    transition: color 0.3s var(--ease-out-quart);
}

.faq-item summary:hover {
    color: var(--primary);
}

.faq-item summary::-webkit-details-marker {
    display: none;
}

.faq-item summary::after {
    content: "+";
    position: absolute;
    top: 50%;
    right: 22px;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-round);
    background: rgba(87, 178, 108, 0.12);
    color: var(--primary);
    font-size: 1.15rem;
    font-weight: 900;
    transform: translateY(-50%) rotate(0);
    transition:
            transform 0.5s var(--ease-spring),
            background 0.3s var(--ease-out-quart),
            color 0.3s var(--ease-out-quart);
}

.faq-item summary:hover::after {
    background: rgba(87, 178, 108, 0.22);
    transform: translateY(-50%) scale(1.1);
}

.faq-item[open] summary::after {
    content: "−";
    background: var(--primary);
    color: #fff;
    transform: translateY(-50%) rotate(180deg);
}

.faq-item p {
    padding: 0 26px 26px;
    animation: faqReveal 0.5s var(--ease-out-expo);
}

@keyframes faqReveal {
    from {
        opacity: 0;
        transform: translateY(-8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ============== CONTACT ============== */
.contact-layout {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 28px;
    align-items: start;
}

.contact-info-column {
    display: grid;
    gap: 18px;
}

.contact-info-card {
    padding: 24px 22px;
    border-radius: 24px;
}

.contact-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 12px;
    border-radius: 14px;
    font-size: 1.35rem;
    line-height: 1;
}

.contact-icon svg {
    width: 22px;
    height: 22px;
}

.contact-info-card:hover .contact-icon {
    transform: scale(1.1) rotate(-5deg);
}

.contact-info-card h3 {
    margin-bottom: 6px;
    font-size: 1.05rem;
}

.contact-info-card p {
    color: var(--text-soft);
    font-size: 0.95rem;
}

.contact-form {
    padding: 36px 32px;
    border-radius: 30px;
    transition: box-shadow 0.5s var(--ease-out-expo);
}

.contact-form:hover {
    box-shadow: var(--shadow-medium);
}

.contact-form h3 {
    margin-bottom: 22px;
    font-size: 1.4rem;
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
}

.form-group + .form-group {
    margin-top: 18px;
}

.form-grid .form-group + .form-group {
    margin-top: 0;
}

.form-group label {
    display: inline-block;
    margin-bottom: 8px;
    color: var(--text-main);
    font-size: 0.93rem;
    font-weight: 800;
    transition: color 0.3s var(--ease-out-quart);
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 15px 16px;
    border: 1.5px solid rgba(16, 30, 20, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--text-main);
    font-size: 0.95rem;
    transition:
            border-color 0.35s var(--ease-out-quart),
            box-shadow 0.35s var(--ease-out-quart),
            background 0.35s var(--ease-out-quart),
            transform 0.3s var(--ease-out-quart);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
    color: var(--text-muted);
    transition: opacity 0.3s var(--ease-out-quart);
}

.form-group input:hover,
.form-group textarea:hover {
    border-color: rgba(47, 122, 67, 0.25);
    background: rgba(255, 255, 255, 0.85);
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: rgba(47, 122, 67, 0.5);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 0 0 4px rgba(87, 178, 108, 0.14);
    transform: translateY(-1px);
}

.form-group input:focus::placeholder,
.form-group textarea:focus::placeholder {
    opacity: 0.5;
}

.form-group:focus-within label {
    color: var(--primary);
}

.form-group textarea {
    min-height: 120px;
    resize: vertical;
    font-family: inherit;
}

.honeypot-field {
    position: absolute;
    top: -9999px;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
}

.contact-form .btn {
    margin-top: 22px;
}

.form-note {
    margin-top: 14px;
    color: var(--text-muted);
    font-size: 0.88rem;
}

#formStatus {
    min-height: 1.4em;
    transition: color 0.3s var(--ease-out-quart);
}

#formStatus:not(:empty) {
    padding-top: 2px;
}

.contact-form .btn[disabled],
.contact-form .btn[aria-busy="true"] {
    opacity: 0.65;
    cursor: not-allowed;
    pointer-events: none;
}

/* ============== LINKS ============== */
.contact-info-card a,
.partner-card a,
.footer-contact a,
.footer-admin-link a {
    position: relative;
    color: var(--primary);
    font-weight: 800;
    word-break: break-word;
    transition: color 0.3s var(--ease-out-quart);
}

.contact-info-card a::after,
.footer-contact a::after,
.footer-admin-link a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s var(--ease-out-expo);
}

.contact-info-card a:hover::after,
.footer-contact a:hover::after,
.footer-admin-link a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
}

/* ============== SOCIAL LINKS ============== */
.social-links-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.social-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 18px;
}

.social-link {
    position: relative;
    isolation: isolate;
    width: 54px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 50%;
    color: #fff;
    box-shadow: 0 14px 30px rgba(15, 27, 20, 0.16);
    transition:
            transform 0.45s var(--ease-spring),
            box-shadow 0.45s var(--ease-out-quart),
            filter 0.35s var(--ease-out-quart);
}

.social-link::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 1;
    transition:
            transform 0.55s var(--ease-out-expo),
            opacity 0.35s var(--ease-out-quart);
}

.social-link::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.26), transparent 42%, rgba(255, 255, 255, 0.1));
}

.social-link:hover {
    transform: translateY(-7px) scale(1.08);
    box-shadow:
            0 22px 46px rgba(15, 27, 20, 0.24),
            0 0 32px rgba(87, 178, 108, 0.16);
    filter: saturate(1.08);
}

.social-link:hover::before {
    transform: scale(1.12) rotate(8deg);
}

.social-link:active {
    transform: translateY(-3px) scale(0.97);
}

.social-icon {
    position: relative;
    z-index: 2;
    width: 24px;
    height: 24px;
    fill: currentColor;
    transition: transform 0.45s var(--ease-spring);
}

.social-link:hover .social-icon {
    transform: scale(1.12);
}

.social-link-x {
    background: #000;
}

.social-link-x::before {
    background: radial-gradient(circle at 30% 25%, #3b3b3b, #000 62%);
}

.social-link-youtube {
    background: #ff0000;
}

.social-link-youtube::before {
    background: radial-gradient(circle at 30% 25%, #ff4d4d, #ff0000 62%);
}

.social-link-instagram {
    background: linear-gradient(135deg, #feda75, #fa7e1e, #d62976, #962fbf, #4f5bd5);
}

.social-link-instagram::before {
    background:
            radial-gradient(circle at 30% 108%, #feda75 0%, #feda75 20%, transparent 42%),
            radial-gradient(circle at 18% 18%, #fa7e1e 0%, transparent 36%),
            linear-gradient(135deg, #d62976, #962fbf, #4f5bd5);
}

.social-link-linkedin {
    background: #0a66c2;
}

.social-link-linkedin::before {
    background: radial-gradient(circle at 30% 25%, #2f8ee8, #0a66c2 62%);
}

/* ============== EU DISCLAIMER ============== */
.eu-disclaimer {
    padding: 0 0 30px;
}

.disclaimer-card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 26px 30px;
    border-radius: 28px;
    transition: box-shadow 0.5s var(--ease-out-expo);
}

.disclaimer-card:hover {
    box-shadow: var(--shadow-medium);
}

.disclaimer-icon {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(87, 178, 108, 0.14), rgba(184, 255, 122, 0.18));
    color: var(--primary);
}

.disclaimer-icon svg {
    width: 22px;
    height: 22px;
}

.disclaimer-card p {
    flex: 1;
    color: var(--text-soft);
    font-size: 0.94rem;
    line-height: 1.65;
}

/* ============== FOOTER ============== */
.site-footer {
    position: relative;
    margin-top: 0;
    padding: 50px 0;
    overflow: hidden;
    background:
            radial-gradient(circle at top center, rgba(87, 178, 108, 0.1), transparent 30%),
            linear-gradient(180deg, #101b13 0%, #0b140e 100%);
    color: rgba(248, 255, 249, 0.94);
}

.site-footer::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.04) 45%, transparent 100%);
    animation: footerSweep 10s linear infinite;
}

@keyframes footerSweep {
    0% {
        transform: translateX(-110%);
    }

    100% {
        transform: translateX(110%);
    }
}

.footer-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: 30px;
    flex-wrap: wrap;
}

.footer-brand h3 {
    margin-bottom: 8px;
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, #fff, var(--accent));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
}

.footer-brand p,
.footer-contact p,
.footer-bottom p {
    color: rgba(248, 255, 249, 0.72);
}

.footer-contact p {
    margin-bottom: 6px;
}

.footer-logos-section,
.footer-partners-section {
    position: relative;
    z-index: 1;
    margin-top: 38px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.footer-partners-section {
    margin-top: 42px;
}

.footer-logos-title {
    margin-bottom: 24px;
    color: rgba(248, 255, 249, 0.78);
    text-align: center;
    font-size: 0.95rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.footer-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 22px;
}

.footer-logo {
    object-fit: contain;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
    filter: saturate(0.92);
    transition:
            transform 0.5s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart),
            filter 0.4s var(--ease-out-quart);
}

.footer-logo:hover {
    transform: translateY(-6px) scale(1.04);
    box-shadow:
            0 20px 42px rgba(0, 0, 0, 0.28),
            0 0 30px rgba(184, 255, 122, 0.2);
    filter: saturate(1.1);
}

.official-logo {
    width: auto;
    height: 72px;
    padding: 14px 18px;
}

.official-logo-wide {
    height: 76px;
    padding: 14px 22px;
}

.partner-logos {
    gap: 28px;
}

.partner-logo {
    width: auto;
    height: 90px;
    padding: 14px 18px;
}

.partner-logo-square {
    width: 110px;
    height: 90px;
    object-fit: contain;
}

.partner-logo-wide {
    width: 260px;
    height: 90px;
    object-fit: contain;
}

.footer-bottom {
    position: relative;
    z-index: 1;
    margin-top: 36px;
    text-align: center;
}

.footer-bottom p {
    color: rgba(248, 255, 249, 0.68);
    font-size: 0.95rem;
}

.designed-by {
    position: relative;
    z-index: 1;
    margin-top: 18px;
    color: rgba(248, 255, 249, 0.4);
    text-align: center;
    font-size: 0.82rem;
    transition: color 0.4s var(--ease-out-quart);
}

.designed-by:hover {
    color: rgba(248, 255, 249, 0.8);
}

.footer-admin-link {
    position: relative;
    z-index: 1;
    margin-top: 12px;
    text-align: center;
    font-size: 0.82rem;
}

.footer-admin-link a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(248, 255, 249, 0.58);
    font-weight: 700;
}

.footer-admin-link a:hover {
    color: var(--accent);
}

/* ============== BACK TO TOP ============== */
.back-to-top {
    position: fixed;
    right: 28px;
    bottom: 28px;
    z-index: 2900;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    color: #fff;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.8);
    box-shadow:
            0 14px 30px rgba(47, 122, 67, 0.32),
            inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition:
            opacity 0.45s var(--ease-out-quart),
            transform 0.5s var(--ease-spring),
            box-shadow 0.4s var(--ease-out-quart);
}

.back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
}

.back-to-top:hover {
    transform: translateY(-4px) scale(1.06);
    box-shadow:
            0 22px 44px rgba(47, 122, 67, 0.42),
            0 0 30px rgba(87, 178, 108, 0.3),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.back-to-top svg {
    width: 22px;
    height: 22px;
    transition: transform 0.4s var(--ease-spring);
}

.back-to-top:hover svg {
    transform: translateY(-3px);
}

/* ============== REVEAL ============== */
.reveal-item {
    opacity: 0;
    transform: translateY(40px) scale(0.98);
    filter: blur(6px);
    transition:
            opacity 1s var(--ease-out-expo),
            transform 1s var(--ease-out-expo),
            filter 0.8s var(--ease-out-quart);
}

.reveal-item.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
}

/* ============== CMS / ADMIN SUPPORT ============== */
[data-cms-section] {
    scroll-margin-top: 120px;
}

[data-cms-collection] {
    position: relative;
}

[data-cms-item] {
    min-width: 0;
}

[data-status="coming-soon"] {
    position: relative;
}

[data-status="coming-soon"]::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    pointer-events: none;
}

/* ============== UTILITIES ============== */
.is-pressed {
    transform: scale(0.97) !important;
    transition-duration: 0.1s !important;
}

/* ============== RESPONSIVE ============== */
@media (max-width: 1180px) {
    .hero-container {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .hero-content {
        max-width: 100%;
        text-align: center;
    }

    .hero-description {
        margin-left: auto;
        margin-right: auto;
    }

    .hero-buttons,
    .hero-stats {
        justify-content: center;
    }

    .hero-visual {
        min-height: 460px;
    }

    .hero-image-card {
        margin-left: 0;
    }

    .chip-1 {
        left: 30px;
    }

    .chip-3 {
        left: 50px;
        bottom: 6px;
    }

    .about-grid,
    .highlights-grid,
    .timeline-grid,
    .gallery-grid,
    .news-grid,
    .outputs-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .mission-strip {
        grid-template-columns: 1fr;
    }

    .contact-layout {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 1100px) {
    .nav-menu-desktop .nav-link {
        padding: 10px 12px;
        font-size: 0.9rem;
    }

    .logo-text {
        font-size: 0.95rem;
    }
}

