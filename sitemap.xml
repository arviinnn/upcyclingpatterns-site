    }

    .hero-visual {
        min-height: 360px;
    }

    .floating-chip {
        padding: 10px 16px;
        font-size: 0.82rem;
    }

    .about-grid,
    .highlights-grid,
    .timeline-grid,
    .gallery-grid,
    .news-grid,
    .outputs-grid {
