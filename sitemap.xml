    }

    .hero-buttons {
        justify-content: center;
    }

    .btn {
        width: 100%;
        max-width: 340px;
    }

    .hero-stats {
        display: grid;
        grid-template-columns: 1fr;
        width: 100%;
    }

    .stat-card {
