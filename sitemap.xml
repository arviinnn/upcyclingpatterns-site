        display: block;
        min-height: auto;
    }

    .hero-image-card {
        margin-bottom: 14px;
    }

    .floating-chip {
        margin-inline: auto;
    }

    .footer-logo {
        width: calc(50% - 10px);
        min-width: 120px;
        height: 46px;
    }

    .official-logo-wide {
        width: min(100%, 240px);
        height: auto;
    }

    .partner-logo-wide,
    .partner-logo-square {
        width: min(100%, 220px);
