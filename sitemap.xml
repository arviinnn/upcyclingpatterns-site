    .site-header {
        padding: 14px 0;
    }

    .navbar {
        min-height: 72px;
    }

    .nav-menu-desktop {
        display: none;
    }

    .desktop-toggle {
        display: inline-flex;
    }

    .hero-section {
        padding: 140px 0 80px;
    }

    .section {
        padding: 90px 0;
    }

    .partners-grid {
        grid-template-columns: 1fr;
    }

    .project-layout {
        grid-template-columns: 1fr;
    }

    .disclaimer-card {
        flex-direction: column;
        text-align: left;
    }

    .footer-content {
        flex-direction: column;
    }
}

@media (max-width: 760px) {
    .container {
        width: min(100% - 28px, var(--container));
    }

    .hero-section {
        min-height: auto;
        padding: 132px 0 70px;
    }

    .hero-title {
        font-size: clamp(2.7rem, 12vw, 4.2rem);
    }

    .hero-description {
